{
  "name": "monaco-editor-nls-adapter",
  "version": "2.0.0",
  "description": "Multi-language NLS adapter for Monaco Editor 0.50.0+ (Self-hosted)",
  "main": "index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./lite": {
      "import": "./lite.js",
      "require": "./lite.js"
    },
    "./proxy": {
      "types": "./proxy.d.ts",
      "require": "./proxy.js"
    },
    "./loader": {
      "types": "./loader.d.ts",
      "require": "./loader.js"
    },
    "./vite-plugin": {
      "types": "./vite-plugin.d.ts",
      "require": "./vite-plugin.js"
    },
    "./transform": {
      "types": "./transform.d.ts",
      "require": "./transform.js"
    },
    "./locales/*": "./locales/*"
  },
  "files": [
    "index.js",
    "lite.js",
    "index.d.ts",
    "loader.js",
    "proxy.js",
    "transform.js",
    "vite-plugin.js",
    "locales/",
    "README.md",
    "README_zh.md"
  ],
  "scripts": {
    "minify-locales": "for f in locales/*.json; do jq -c . \"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; done",
    "prepublishOnly": "npm run minify-locales"
  },
  "keywords": [
    "monaco-editor",
    "nls",
    "localization",
    "internationalization",
    "i18n",
    "vite-plugin",
    "webpack-loader"
  ],
  "author": "leepule",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:leepule/monaco-editor-nls-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/leepule/monaco-editor-nls-adapter/issues"
  },
  "homepage": "https://github.com/leepule/monaco-editor-nls-adapter#readme",
  "peerDependencies": {
    "monaco-editor": ">= 0.50.0"
  },
  "dependencies": {
    "magic-string": "^0.30.0"
  }
}
